@page "/"

<PageTitle>Home</PageTitle>

<section class="hero">
    <h1>Welcome to EventEase</h1>
    <p>Plan events, register attendees, and track attendance in one beginner-friendly app.</p>
    <div class="hero__actions">
        <a class="btn btn-primary" href="events">Browse Events</a>
        <a class="btn btn-outline-primary" href="register">Register Now</a>
    </div>
</section>

<section class="mt-4">
    <h2>What you can do</h2>
    <div class="feature-grid">
        <div class="feature-card">
            <h3>Explore Event Cards</h3>
            <p>See all upcoming events with venue, date, and capacity details.</p>
        </div>
        <div class="feature-card">
            <h3>Register with Validation</h3>
            <p>Use a guided form with built-in validation to avoid mistakes.</p>
        </div>
        <div class="feature-card">
            <h3>Track Attendance</h3>
            <p>Quickly mark attendees as present and monitor check-in status.</p>
        </div>
    </div>
</section>
