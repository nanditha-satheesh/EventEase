@using EventEase.Models

@* Reusable Event Card Component with parameters and two-way binding *@

<div class="event-card">
    <div class="event-card-header">
        <h3 class="event-title">@EventData.Name</h3>
        <span class="event-category">@EventData.Category</span>
    </div>
    
    <div class="event-card-body">
        <div class="event-info">
            <div class="info-item">
                <span class="info-icon">📅</span>
                <span class="info-text">@EventData.Date.ToString("MMM dd, yyyy")</span>
            </div>
            
            <div class="info-item">
                <span class="info-icon">⏰</span>
                <span class="info-text">@EventData.Date.ToString("hh:mm tt")</span>
            </div>
            
            <div class="info-item">
                <span class="info-icon">📍</span>
                <span class="info-text">@EventData.Location</span>
            </div>
            
            <div class="info-item">
                <span class="info-icon">💺</span>
                <span class="info-text">@EventData.AvailableSeats seats available</span>
            </div>
        </div>
        
        <p class="event-description">@EventData.Description</p>
    </div>
    
    <div class="event-card-footer">
        @if (ShowRegisterButton)
        {
            <button class="btn-register" @onclick="HandleRegisterClick">
                Register Now
            </button>
        }
        
        @if (ShowDetailsButton)
        {
            <button class="btn-details" @onclick="HandleDetailsClick">
                View Details
            </button>
        }
    </div>
</div>

@code {
    // Component parameters for reusability
    [Parameter]
    public Event EventData { get; set; } = new();

    [Parameter]
    public bool ShowRegisterButton { get; set; } = true;

    [Parameter]
    public bool ShowDetailsButton { get; set; } = false;

    [Parameter]
    public EventCallback<Event> OnRegisterClicked { get; set; }

    [Parameter]
    public EventCallback<Event> OnDetailsClicked { get; set; }

    // Two-way binding parameter example
    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback<bool> IsSelectedChanged { get; set; }

    private async Task HandleRegisterClick()
    {
        IsSelected = true;
        await IsSelectedChanged.InvokeAsync(IsSelected);
        await OnRegisterClicked.InvokeAsync(EventData);
    }

    private async Task HandleDetailsClick()
    {
        await OnDetailsClicked.InvokeAsync(EventData);
    }
}
